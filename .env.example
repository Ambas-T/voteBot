# Copy to .env and adjust. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEV   →  TOR_ENABLED=true, SHOW_BROWSER=true (optional), npm run dev
# RAILWAY     →  set ACCOUNT_PASSWORD + GROQ_API_KEY in Railway env vars
#                TOR_ENABLED must be false/unset on Railway (no Tor daemon)
#                PORT is auto-set by Railway
# ─────────────────────────────────────────────────────────────────────────────

UI_PORT=3000

# How many votes to run in one browser instance before rotating the Tor circuit.
# Set to 1 for a fresh Tor exit node on every single vote.
VOTES_PER_SESSION=1

# Set to "true" to watch the Chromium window (local only)
SHOW_BROWSER=false
SLOW_MO=0

# Password used for every creativeaward.ai signup account
ACCOUNT_PASSWORD=ta123#$55

# ── Tor (local only; leave TOR_ENABLED=false on Vercel) ──────────────────────
TOR_ENABLED=false
TOR_PROXY_PORT=9150
TOR_CONTROL_PORT=9151
# TOR_CONTROL_PASSWORD=
# TOR_COOKIE_FILE=

# Comma-separated HTTP/HTTPS proxies (optional; Tor takes priority when enabled)
PROXIES=

# ── Groq — Ethiopian name generation ─────────────────────────────────────────
# Get a free key at https://console.groq.com/
# Without a key the bot still works, using a local Ethiopian name pool.
GROQ_API_KEY=
