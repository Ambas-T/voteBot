# ─────────────────────────────────────────────────────────────────────────────
# VoteBot — environment variables
# Copy this file to .env and fill in the values for local development.
# On Vercel, add these under Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# Password used when registering accounts on creativeaward.ai
ACCOUNT_PASSWORD=ta123#$55

# How many emails to process before rotating the Tor circuit (local only)
EMAILS_PER_SESSION=2

# ── Local development ──────────────────────────────────────────────────────

# Set to "true" to see the browser window (local only, ignored on Vercel)
SHOW_BROWSER=false

# Slow-motion delay in ms for Playwright actions (0 = off, local only)
SLOW_MO=0

# ── Tor (local only — Tor Browser must be running) ────────────────────────

TOR_ENABLED=false
TOR_PROXY_PORT=9150
TOR_CONTROL_PORT=9151
# TOR_CONTROL_PASSWORD=your_password_here
# TOR_COOKIE_FILE=C:\path\to\control_auth_cookie

# ── Proxy rotation (works both locally and on Vercel) ─────────────────────
# Comma-separated list:  http://user:pass@host:port
# Leave blank to use no proxy (Vercel uses its own egress IPs)
PROXIES=

# ── Vercel-specific ────────────────────────────────────────────────────────
# Set this in the Vercel dashboard to prevent Playwright downloading a browser
# (Vercel uses @sparticuz/chromium instead):
#   PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD = 1

# Server port (local only — Vercel assigns its own port)
UI_PORT=3000
